<!-- Fun Stuff! -->

<table>
  <tr>
    <th>Amount</th>
    <th>From</th>
    <th>To</th>
  </tr>

  <% for t in @transactions %>
    <% if t.from_user_id == nil %>
      <tr>
        <td><%= t.amount %></td>
        <td>ICO</td>
        <td><%= User.find_by({"id" => t.to_user_id})["name"] %></td>
      </tr>
    <% else %>
      <tr>
        <td><%= t.amount %></td>
        <td><%= User.find_by({"id" => t.from_user_id})["name"] %></td>
        <td><%= User.find_by({"id" => t.to_user_id})["name"] %></td>
      </tr>
    <% end %>
  <% end %>
</table>