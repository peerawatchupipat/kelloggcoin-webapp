<!-- Step 2: Calculate and display the balances -->
<!-- balance = coins received - coins sent-->
<!-- 
┌─ START: pick a user (Brian) ──────────────────┐
│                                               │
│  1. Set received = 0                          │
│                                               │
│  ┌─ inner loop 1 (received) ─────────────┐    │
│  │  find all transactions to Brian       │    │
│  │  keep adding to received              │    │
│  └───────────────────────────────────────┘    │
│                                               │
│  2. Set sent = 0                              │
│                                               │
│  ┌─ inner loop 2 (sent) ──────────────────┐   │
│  │  find all transactions from Brian      │   │
│  │  keep adding to sent                   │   │
│  └────────────────────────────────────────┘   │
│                                               │
│  3. balance = received - sent                 │
│  4. Print Brian's balance                     │
│                                               │
└─ DONE with Brian. Now pick next user (Ben) ───┘ -->

<% for u in @users %>
  <% received = 0 %>
  <% for transaction in Transaction.where({"to_user_id" => u["id"]}) %>
    <% received = received + transaction["amount"] %>
  <% end %>

  <% sent = 0 %>
  <% for transaction in Transaction.where({"from_user_id" => u["id"]}) %>
    <% sent = sent + transaction["amount"] %>
  <% end %>

  <% balance = received - sent %>
  <p><%= "Balance for #{u["name"]}" %>: <%= balance %> KC</p>
<% end %>

